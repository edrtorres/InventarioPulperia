<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_image"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:id="@+id/txtTituloDialogoImagen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Imagen del producto"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnDialogCamara"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_dialog_option"
        android:gravity="center"
        android:padding="15dp"
        android:text="Tomar foto"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnDialogGaleria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_dialog_option"
        android:gravity="center"
        android:padding="15dp"
        android:text="Seleccionar de galería"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnDialogCancelar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:padding="12dp"
        android:text="Cancelar"
        android:textColor="@color/warning_color"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>